type Tests {
  let project: Directory! = Dagger
    .currentModule
    .source
    .directory("fixtures/project")
  let packages: Directory! = Dagger
    .currentModule
    .source
    .directory("fixtures/packages")

  let pack: File! {
    Dagger.typstPack.create(
      project: self.project,
      input: "main.typ",
      packageDir: self.packages,
      include: ["notes.txt"],
      certificate: self.project.file("notes.txt"),
    )
  }

  """
  Create a pack and inspect its discovered project files and vendored package.
  """
  createInspect: Void @check {
    let pack = self.pack
    let output = Dagger.typstPack.inspect(pack)

    assert { pack.name == "project.typk" }
    assert { output.contains("entrypoint: main.typ") }
    assert { output.contains("packed project files:") }
    assert { output.contains("main.typ") }
    assert { output.contains("chapters/intro.typ") }
    assert { output.contains("data.csv") }
    assert { output.contains("notes.txt") }
    assert { output.contains("@local/greet:0.1.0") }

    null
  }

  """
  Create, inspect, and compile a pack whose package dependency is not vendored.
  """
  noVendorPackagesLifecycle: Void @check {
    let pack = Dagger.typstPack.create(
      project: self.project,
      input: "main.typ",
      noVendorPackages: true,
      packageDir: self.packages,
      offline: true,
    )
    let inspection = Dagger.typstPack.inspect(pack)

    assert { inspection.contains("unvendored packages:") }
    assert { inspection.contains("@local/greet:0.1.0") }

    let output = Dagger.typstPack.compile(
      pack: pack,
      format: TypstPackOutputFormat.SVG,
      packageDir: self.packages,
      offline: true,
    )
    assert { output.file("page-1.svg").size > 0 }

    null
  }

  """
  Extract a pack back into project files and vendored packages.
  """
  extract: Void @check {
    let extracted = Dagger.typstPack.extract(pack: self.pack, packages: true)

    assert {
      extracted
        .file("main.typ")
        .contents
        .contains("@local/greet:0.1.0")
    }
    assert {
      extracted
        .file("chapters/intro.typ")
        .contents
        .contains("Introduction")
    }
    assert {
      extracted
        .file("data.csv")
        .contents == "a,b\n1,2\n"
    }
    assert {
      extracted
        .file("notes.txt")
        .contents == "extra\n"
    }
    assert {
      extracted
        .file("packages/local/greet/0.1.0/lib.typ")
        .contents
        .contains("Hello")
    }
    assert {
      extracted
        .file("packages/local/greet/0.1.0/typst.toml")
        .contents
        .contains("name = \"greet\"")
    }

    null
  }

  """
  Compile PDFs with observable standard and timestamp controls.
  """
  compilePdf: Void @check {
    let baseline = Dagger
      .typstPack
      .compile(
        pack: self.pack,
        creationTimestamp: 1700000000,
      )
      .file("output.pdf")
    let standard = Dagger
      .typstPack
      .compile(
        pack: self.pack,
        creationTimestamp: 1700000000,
        pdfStandards: [TypstPackPdfStandard.V2_0],
        diagnosticFormat: TypstPackDiagnosticFormat.SHORT,
        certificate: self.project.file("notes.txt"),
      )
      .file("output.pdf")
    let later = Dagger
      .typstPack
      .compile(
        pack: self.pack,
        creationTimestamp: 1700000001,
      )
      .file("output.pdf")

    assert { standard.name == "output.pdf" }
    assert { standard.size > 0 }
    assert { baseline.digest != standard.digest }
    assert { baseline.digest != later.digest }

    null
  }

  """
  Discover and union dependencies from paged and HTML targets.
  """
  discoveryTargets: Void @check {
    let source = Dagger
      .currentModule
      .source
      .directory("fixtures/targets")
    let pack = Dagger.typstPack.create(
      project: source,
      input: "main.typ",
      targets: [TypstPackDiscoveryTarget.PAGED, TypstPackDiscoveryTarget.HTML],
      features: [TypstPackFeature.HTML],
      diagnosticFormat: TypstPackDiagnosticFormat.SHORT,
      ignoreSystemFonts: true,
    )
    let output = Dagger.typstPack.inspect(pack)

    assert { output.contains("paged.txt") }
    assert { output.contains("html.txt") }

    null
  }

  """
  Forward sys.inputs through Pack creation, inspection, and final compilation.
  """
  sysInputsLifecycle: Void @check {
    let source = Dagger
      .currentModule
      .source
      .directory("fixtures/sys-inputs")
    let discoveryResources = source.directory("resources")
    let pack = Dagger.typstPack.create(
      project: source,
      input: "main.typ",
      sysInputs: ["phase=discovery"],
      resourceDirs: [discoveryResources],
      ignoreSystemFonts: true,
      ignoreEmbeddedFonts: true,
    )
    let inspection = Dagger.typstPack.inspect(pack)

    assert { inspection.contains("discovered.txt") }

    let output = Dagger.typstPack.compile(
      pack: pack,
      format: TypstPackOutputFormat.SVG,
      sysInputs: ["phase=compilation"],
      ignoreSystemFonts: true,
      ignoreEmbeddedFonts: true,
    )

    assert { output.file("page-1.svg").size > 0 }

    null
  }

  """
  Embed the fonts used during discovery when requested.
  """
  fontControls: Void @check {
    let pack = Dagger.typstPack.create(
      project: self.project,
      input: "main.typ",
      packageDir: self.packages,
      embedFonts: true,
      includeTypstEmbeddedFonts: true,
      ignoreSystemFonts: true,
    )
    let output = Dagger.typstPack.inspect(pack)

    assert { output.contains("embedded fonts:") }

    null
  }

  """
  Compile a pack to PNG.
  """
  compilePng: Void @check {
    let output = Dagger.typstPack.compile(
      pack: self.pack,
      format: TypstPackOutputFormat.PNG,
    )
    let png = output.file("page-1.png")

    assert { png.name == "page-1.png" }
    assert { png.size > 0 }

    null
  }

  """
  Preserve omitted and fractional PPI values across the module boundary.
  """
  compilePpi: Void @check {
    let default = Dagger
      .typstPack
      .compile(pack: self.pack, format: TypstPackOutputFormat.PNG)
      .file("page-1.png")
    let explicitDefault = Dagger
      .typstPack
      .compile(pack: self.pack, format: TypstPackOutputFormat.PNG, ppi: "144")
      .file("page-1.png")
    let fractional = Dagger
      .typstPack
      .compile(pack: self.pack, format: TypstPackOutputFormat.PNG, ppi: "72.5")
      .file("page-1.png")
    assert { default.digest == explicitDefault.digest }
    assert { default.digest != fractional.digest }

    null
  }

  """
  Reject an explicitly empty PPI value through the public compile function.
  """
  compileRejectsEmptyPpi: Void @check {
    #nofmt Dagger's embedded Dang still requires try/catch.
    let rejected = try {
      let count = Dagger
        .typstPack
        .compile(pack: self.pack, format: TypstPackOutputFormat.PNG, ppi: "")
        .entries
        .length
      count < 0
    } catch {
      error: Error => {
        assert { error.message.contains("cannot parse float from empty string") }
        true
      }
    }
    assert { rejected }

    null
  }

  """
  Compile selected source pages to deterministically named page artifacts.
  """
  compileSelectedPages: Void @check {
    let source = Dagger
      .currentModule
      .source
      .directory("fixtures/multi-page")
    let pack = Dagger.typstPack.create(
      project: source,
      input: "main.typ",
      features: [TypstPackFeature.A11Y_EXTRAS],
      ignoreSystemFonts: true,
      ignoreEmbeddedFonts: true,
    )
    let output = Dagger.typstPack.compile(
      pack: pack,
      format: TypstPackOutputFormat.PNG,
      pages: "5,2",
      ppi: "144.5",
      ignoreSystemFonts: true,
      ignoreEmbeddedFonts: true,
    )
    let entries = output.entries

    assert { entries.length == 2 }
    assert { entries.contains("page-2.png") }
    assert { entries.contains("page-5.png") }
    assert { output.file("page-2.png").size > 0 }
    assert { output.file("page-5.png").size > 0 }

    null
  }

  """
  Compile a pack to HTML with Typst's experimental HTML feature enabled.
  """
  compileHtml: Void @check {
    let output = Dagger.typstPack.compile(
      pack: self.pack,
      format: TypstPackOutputFormat.HTML,
      features: [TypstPackFeature.HTML],
    )
    let html = output.file("output.html")

    assert { html.name == "output.html" }
    assert { html.contents.contains("Dagger") }

    null
  }

  """
  Create and compile a pack with ordered Resource Providers.
  """
  resourceSlots: Void @check {
    let project = Dagger
      .currentModule
      .source
      .directory("fixtures/resource-project")
    let resources = Dagger
      .currentModule
      .source
      .directory("fixtures/resources")
    let pack = Dagger.typstPack.create(
      project: project,
      input: "main.typ",
      resourceDirs: [resources.directory("first"), resources.directory("second")],
      resourceSlots: ["branding/conditional.txt"],
    )
    let output = Dagger.typstPack.inspect(pack)

    assert { output.contains("Resource Slots:") }
    assert { output.contains("branding/name.txt") }
    assert { output.contains("branding/first-only.txt") }
    assert { output.contains("branding/from-second-root.txt") }
    assert { output.contains("branding/conditional.txt") }
    assert { !output.contains("branding/second-only.txt") }

    let pdf = Dagger
      .typstPack
      .compile(
        pack: pack,
        resourceDirs: [resources.directory("first"), resources.directory("second")],
      )
      .file("output.pdf")
    assert { pdf.size > 0 }

    null
  }
}
