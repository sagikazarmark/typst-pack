type Tests {
  let project: Directory! = Dagger
    .currentModule
    .source
    .directory("fixtures/project")
  let packages: Directory! = Dagger
    .currentModule
    .source
    .directory("fixtures/packages")

  let pack: File! {
    Dagger.typstPack.create(
      source: self.project,
      packageDir: self.packages,
      include: ["notes.txt"],
    )
  }

  """
  Create a pack and inspect its discovered project files and vendored package.
  """
  createInspect: Void @check {
    let pack = self.pack
    let output = Dagger.typstPack.inspect(pack)

    assert { pack.name == "project.typk" }
    assert { output.contains("entrypoint: main.typ") }
    assert { output.contains("packed project files:") }
    assert { output.contains("main.typ") }
    assert { output.contains("chapters/intro.typ") }
    assert { output.contains("data.csv") }
    assert { output.contains("notes.txt") }
    assert { output.contains("@local/greet:0.1.0") }

    null
  }

  """
  Extract a pack back into project files and vendored packages.
  """
  extract: Void @check {
    let extracted = Dagger.typstPack.extract(pack: self.pack, packages: true)

    assert {
      extracted
        .file("main.typ")
        .contents
        .contains("@local/greet:0.1.0")
    }
    assert {
      extracted
        .file("chapters/intro.typ")
        .contents
        .contains("Introduction")
    }
    assert {
      extracted
        .file("data.csv")
        .contents == "a,b\n1,2\n"
    }
    assert {
      extracted
        .file("notes.txt")
        .contents == "extra\n"
    }
    assert {
      extracted
        .file("packages/local/greet/0.1.0/lib.typ")
        .contents
        .contains("Hello")
    }
    assert {
      extracted
        .file("packages/local/greet/0.1.0/typst.toml")
        .contents
        .contains("name = \"greet\"")
    }

    null
  }

  """
  Compile a pack to PDF using SOURCE_DATE_EPOCH for reproducible metadata.
  """
  compilePdf: Void @check {
    let output = Dagger.typstPack.compile(
      pack: self.pack,
      sourceDateEpoch: "1700000000",
    )
    let pdf = output.file("output.pdf")

    assert { pdf.name == "output.pdf" }
    assert { pdf.size > 0 }

    null
  }

  """
  Compile a pack to PNG.
  """
  compilePng: Void @check {
    let output = Dagger.typstPack.compile(
      pack: self.pack,
      format: TypstPackOutputFormat.PNG,
    )
    let png = output.file("page-1.png")

    assert { png.name == "page-1.png" }
    assert { png.size > 0 }

    null
  }

  """
  Compile selected source pages to deterministically named page artifacts.
  """
  compileSelectedPages: Void @check {
    let source = Dagger
      .currentModule
      .source
      .directory("fixtures/multi-page")
    let pack = Dagger.typstPack.create(source: source)
    let output = Dagger.typstPack.compile(
      pack: pack,
      format: TypstPackOutputFormat.PNG,
      pages: "5,2",
    )
    let entries = output.entries

    assert { entries.length == 2 }
    assert { entries.contains("page-2.png") }
    assert { entries.contains("page-5.png") }
    assert { output.file("page-2.png").size > 0 }
    assert { output.file("page-5.png").size > 0 }

    null
  }

  """
  Compile a pack to HTML with Typst's experimental HTML feature enabled.
  """
  compileHtml: Void @check {
    let output = Dagger.typstPack.compile(
      pack: self.pack,
      format: TypstPackOutputFormat.HTML,
      features: ["html"],
    )
    let html = output.file("output.html")

    assert { html.name == "output.html" }
    assert { html.contents.contains("Dagger") }

    null
  }

  """
  Create and compile a pack with ordered External Resource References.
  """
  externalProjectResources: Void @check {
    let source = Dagger
      .currentModule
      .source
      .directory("fixtures/resource-project")
    let resources = Dagger
      .currentModule
      .source
      .directory("fixtures/resources")
    let sourceReferences = ["/work/references/first", "/work/references/second"]
    let pack = Dagger.typstPack.create(
      source: source,
      sourceReferenceDir: resources,
      sourceReferences: sourceReferences,
      externalResources: ["branding/conditional.txt"],
    )
    let output = Dagger.typstPack.inspect(pack)

    assert { output.contains("external project resources:") }
    assert { output.contains("branding/name.txt") }
    assert { output.contains("branding/first-only.txt") }
    assert { output.contains("branding/from-second-root.txt") }
    assert { output.contains("branding/conditional.txt") }
    assert { !output.contains("branding/second-only.txt") }

    let pdf = Dagger
      .typstPack
      .compile(
        pack: pack,
        sourceReferenceDir: resources,
        sourceReferences: sourceReferences,
      )
      .file("output.pdf")
    assert { pdf.size > 0 }

    null
  }
}
